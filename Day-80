/*Floyd-Warshall computes shortest paths between all pairs of vertices by progressively allowing each vertex as an intermediate node.

Approach:
1. Initialize distance matrix from input
2. Replace -1 with large infinity value except diagonal
3. For every intermediate vertex k
4. Update dist[i][j] = min(dist[i][j], dist[i][k] + dist[k][j])
5. Convert unreachable INF back to -1*/

#include <stdio.h>
#define INF 1000000000

int main() {
    int n;
    scanf("%d", &n);

    int dist[105][105];

    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            scanf("%d", &dist[i][j]);
            if(dist[i][j] == -1 && i != j)
                dist[i][j] = INF;
        }
    }

    for(int k = 0; k < n; k++) {
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < n; j++) {
                if(dist[i][k] != INF && dist[k][j] != INF && dist[i][k] + dist[k][j] < dist[i][j]) {
                    dist[i][j] = dist[i][k] + dist[k][j];
                }
            }
        }
    }

    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            if(dist[i][j] == INF)
                printf("-1 ");
            else
                printf("%d ", dist[i][j]);
        }
        printf("\n");
    }

    return 0;
}
