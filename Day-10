/*Check if string is palindrome using two pointers:

1. Use left pointer at start, right at end
2. Compare characters at both positions
3. If different, not palindrome
4. Move pointers toward center
5. If all match, it's palindrome*/


#include <stdio.h>
#include <string.h>
#include <stdbool.h>

int main() {
    char str[1000];
    scanf("%s", str);

    int left = 0;
    int right = strlen(str) - 1;
    bool isPalindrome = true;

    while (left < right) {
        if (str[left] != str[right]) {
            isPalindrome = false;
            break;
        }
        left++;
        right--;
    }

    printf("%s\n", isPalindrome ? "YES" : "NO");
    return 0;
}
