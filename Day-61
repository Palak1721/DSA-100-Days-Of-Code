/*Represent a graph using a 2D array (matrix). If there is an edge between vertex i and j, matrix[i][j] = 1 (or weight), otherwise 0.*/

#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n, m;
    cin >> n >> m;
    // 1-based indexing for vertices
    vector<vector<int>> adj(n + 1, vector<int>(n + 1, 0));
    for (int i = 0; i < m; i++) {
        int u, v;
        cin >> u >> v;
        adj[u][v] = 1;
        adj[v][u] = 1; // For undirected graph
    }
    return 0;
}
