/*Compute power using recursion:

1. Base case: a^0 = 1
2. Recursive case: a^b = a * a^(b-1)
3. Can optimize with divide and conquer for O(log n)*/

#include <stdio.h>

int power(int a, int b) {
    // Base case
    if (b == 0) return 1;
    
    // Recursive case
    return a * power(a, b - 1);
}

int main() {
    int a, b;
    scanf("%d %d", &a, &b);
    printf("%d\n", power(a, b));
    return 0;
}
